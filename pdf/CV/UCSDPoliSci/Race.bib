@article{ramasubramanian_impact_2011,
	title = {The Impact of Stereotypical Versus Counterstereotypical Media Exemplars on Racial Attitudes, Causal Attributions, and Support for Affirmative Action},
	volume = {38},
	issn = {0093-6502, 1552-3810},
	url = {http://crx.sagepub.com/content/38/4/497},
	doi = {10.1177/0093650210384854},
	abstract = {This study examines how exposure to media characters of color shapes viewers’ opinions of race-targeted policies. Exemplar-based information processing, attribution theory, and heuristic policy decision-making formed the theoretical foundation for the study. A 2 × 2 factorial experiment (N = 363) exposed participants to stereotypical or counterstereotypical exemplars representing the in-group (Whites) and the out-group (Blacks). The experiment revealed that exposure to stereotypical African American media characters compared to exposure to counter-stereotypical ones influenced real-world beliefs of African American stereotypes, internal attributions for perceived failures of this out-group, prejudicial feelings toward this out-group, and lack of support for pro-minority affirmative action policies. A structural model established “internal attributions for out-group failures” as a crucial mediator. Implications for entertainment studies and political communication are discussed.},
	language = {en},
	number = {4},
	urldate = {2014-02-17},
	journal = {Communication Research},
	author = {Ramasubramanian, Srividya},
	month = aug,
	year = {2011},
	keywords = {exemplars, Experiment, racial attitudes, stereotypes},
	pages = {497--516}
}

